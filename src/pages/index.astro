---
import Milestones from '../components/Milestones.astro';

const navItems = [
  ['Journey', '#journey'],
  ['Capabilities', '#ai'],
  ['Work', '#work'],
  ['People', '#people'],
  ['Insights', '#insights'],
];

const work = [
  [
    'AI',
    'Dynamic Dashboards',
    'Enterprise dashboards for AI-driven decision making and digital transformation initiatives for the leadership.',
    'Dashboard Screenshots'
  ],
  [
    'UX',
    'UI / UX Design',
    'Professional UI and dashboard designs delivered across enterprise platforms.',
    'UI Gallery'
  ],
  [
    'Video',
    'Animation Portfolio',
    'Corporate learning, animation and multimedia projects.',
    'YouTube Videos'
  ],
  [
    'Book',
    'YUVA LSP',
    'Leadership Simulation Program (Coming Soon)',
    'Book Gallery'
  ],
];

const capabilities = [
  ['01', 'Classical Animation', 'Breathing traditional life into characters through frame-by-frame artistry.', 'play'],
  ['02', 'Digital 2D Animation', 'Crafting fluid motion graphics and engaging visual storytelling assets.', 'layers'],
  ['03', 'Video Shooting & Editing', 'Capturing professional footage and weaving raw media into polished cinematic cuts.', 'film'],
  ['04', 'Audio Editing', 'Mixing crisp soundscapes and voiceovers for immersive audience impact.', 'volume'],
  ['05', 'Printing Collaterals', 'Designing tangible marketing assets that elevate physical brand presence.', 'layout'],
  ['06', 'Branding Designing', 'Building cohesive visual identities that define unique market value.', 'target'],
  ['07', 'Newsletters & Emailers', 'Creating targeted digital campaigns that drive active user engagement.', 'mail'],
  ['08', 'PPT Pitch Projects', 'Structuring persuasive presentation decks that secure vital business growth.', 'pie'],
  ['09', 'UI / UX Design', 'Shaping intuitive digital interfaces and user journeys rooted in deep behavioral insights.', 'grid'],
  ['10', 'Planning & Management', 'Orchestrating complex project pipelines from conception to successful launch.', 'chart'],
  ['11', 'eLearning and WBT Projects', 'Developing and managing larger projects to accelerate enterprise scale and digital growth.', 'briefcase'],
  ['12', 'AI-Driven Workflows', 'Integrating artificial intelligence to optimize creative execution and product strategy.', 'cpu'],
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Kumar Shubhek — creativity, product strategy, AI and meaningful digital transformation." />
    <meta name="theme-color" content="#0b0b0d" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Mono&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&family=Playfair+Display:ital,wght@0,500;0,600;1,500;1,600&display=swap" rel="stylesheet" />
    <title>Kumar Shubhek | Human by Design. Intelligent by Innovation.</title>
  </head>
  <body>
    <header class="nav-wrap">
      <nav class="nav container" aria-label="Main navigation">
        <a class="brand" href="#top" aria-label="Kumar Shubhek home">KUMAR SHUBHEK<span>.</span></a>
        <div class="nav-links">
          {navItems.map(([label, href]) => <a href={href}>{label}</a>)}
        </div>
        <a class="nav-contact" href="#contact">Let’s connect <span aria-hidden="true">↗</span></a>
      </nav>
    </header>

    <main id="top">
      <section class="hero container">
        <div class="hero-copy">
          <p class="eyebrow"><span></span> Kumar Shubhek — 2006 to now</p>
          <h1>My career didn’t begin with AI.<br /><em>It began with a pencil.</em></h1>
          <p class="hero-intro">A creative foundation that evolved into product thinking, intelligent experiences, and people-centred transformation.</p>
          <div class="hero-actions">
            <a class="button button-primary" href="#journey">Explore my journey <span>↓</span></a>
            <a class="button button-outline" href="/resume/Shubhek_Kumar_Resume.pdf" download>Resume</a>
            <a class="button button-outline" href="/resume/Shubhek_Kumar_Cover_Letter.pdf" download>Cover Letter</a>
          </div>
        </div>
        <div class="pencil-art">
          <img
            src="/images/shubhek-profile.jpg"
            alt="Shubhek Kumar"
            class="profile-photo"
          />
          <div class="overlay"></div>
          <div class="orbit orbit-one"></div>
          <div class="orbit orbit-two"></div>
          <div class="line line-one"></div>
          <div class="line line-two"></div>
          <p>CREATIVITY → CLARITY → INTELLIGENCE</p>
        </div>
      </section>

      <section class="statement-band">
        <div class="container statement-grid">
          <p class="eyebrow">A different starting point</p>
          <p class="statement">I learned how people feel <em>before</em> I learned how technology works.</p>
        </div>
      </section>

      <!-- Section 01: Journey -->
      <section id="journey" class="section container">
        <div class="section-heading split-heading">
          <div>
            <p class="eyebrow">01 — Journey</p>
            <h2>Every chapter added<br /><em>a new way of seeing.</em></h2>
          </div>
          <p>From animation to AI, the journey has never been a straight line. Each transition has made the next one possible.</p>
        </div>

        <Milestones />
        
        <div style="text-align: center; margin-top: 3rem;">
          <a class="text-link more-link" href="#contact">The journey continues <span>↓</span></a>
        </div>
      </section>

      <!-- Section 02: Capabilities -->
      <section id="ai" class="section container">
        <div class="section-heading split-heading">
          <div>
            <p class="eyebrow">02 — Capabilities</p>
            <h2>Services &amp;<br /><em>End-to-End Expertise</em></h2>
          </div>
          <p>Delivering comprehensive multi-disciplinary support from classical creative foundations to modern intelligent workflows.</p>
        </div>

        <div class="capabilities-grid">
          {capabilities.map(([num, title, desc, iconType]) => (
            <div class="capability-card">
              <div class="capability-header">
                <span class="cap-num">{num}</span>
                <div class="card-icon" aria-hidden="true">
                  {iconType === 'play' && (
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
                  )}
                  {iconType === 'layers' && (
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"></polygon><polyline points="2 17 12 22 22 17"></polyline><polyline points="2 12 12 17 22 12"></polyline></svg>
                  )}
                  {iconType === 'film' && (
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="2.18" ry="2.18"></rect><line x1="7" y1="2" x2="7" y2="22"></line><line x1="17" y1="2" x2="17" y2="22"></line><line x1="2" y1="12" x2="22" y2="12"></line><line x1="2" y1="7" x2="7" y2="7"></line><line x1="2" y1="17" x2="7" y2="17"></line><line x1="17" y1="17" x2="22" y2="17"></line><line x1="17" y1="7" x2="22" y2="7"></line></svg>
                  )}
                  {iconType === 'volume' && (
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon><path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"></path></svg>
                  )}
                  {iconType === 'layout' && (
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="3" y1="9" x2="21" y2="9"></line><line x1="9" y1="21" x2="9" y2="9"></line></svg>
                  )}
                  {iconType === 'target' && (
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><circle cx="12" cy="12" r="6"></circle><circle cx="12" cy="12" r="2"></circle></svg>
                  )}
                  {iconType === 'mail' && (
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                  )}
                  {iconType === 'pie' && (
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.21 15.89A10 10 0 1 1 8 2.83"></path><path d="M22 12A10 10 0 0 0 12 2v10z"></path></svg>
                  )}
                  {iconType === 'grid' && (
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
                  )}
                  {iconType === 'chart' && (
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"></line><line x1="12" y1="20" x2="12" y2="4"></line><line x1="6" y1="20" x2="6" y2="14"></line></svg>
                  )}
                  {iconType === 'briefcase' && (
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path></svg>
                  )}
                  {iconType === 'cpu' && (
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2" ry="2"></rect><rect x="9" y="9" width="6" height="6"></rect><line x1="9" y1="1" x2="9" y2="4"></line><line x1="15" y1="1" x2="15" y2="4"></line><line x1="9" y1="20" x2="9" y2="23"></line><line x1="15" y1="20" x2="15" y2="23"></line><line x1="20" y1="9" x2="23" y2="9"></line><line x1="20" y1="14" x2="23" y2="14"></line><line x1="1" y1="9" x2="4" y2="9"></line><line x1="1" y1="14" x2="4" y2="14"></line></svg>
                  )}
                </div>
              </div>
              <h3>{title}</h3>
              <p>{desc}</p>
            </div>
          ))}
        </div>
      </section>
      
      <!-- Section 03: Work -->
      <section id="work" class="section container">
        <div class="section-heading split-heading">
          <div>
            <p class="eyebrow">03 — Work</p>
            <h2>Different mediums.<br /><em>One craft.</em></h2>
          </div>
          <p>Selected work will appear here as portfolio materials become available. For now, these cards show the stories this website will hold.</p>
        </div>
        <div class="work-grid">
          {work.map(([tag, title, copy, placeholder], index) => (
            <article class:list={['work-card', `work-${index + 1}`]}>
              <div class="work-visual">
                <span class="work-tag">{tag}</span>
                <div class="placeholder-art" aria-hidden="true">
                  {index === 0 && <img src="/images/dashboard-ui.png" alt="Executive Dashboard UI Screenshot" class="work-dashboard-img" />}
                  {index === 1 && <img src="/images/UI-UX.png" alt="UI-UX Banner" class="UI-UX-img" />}
                  
                  {index === 2 && (
                    <div class="youtube-player-cluster">
                      <div class="video-frame-wrapper">
                        <iframe width="100%" height="100%" src="https://www.youtube.com/embed/0NmTmCAUKhU" title="Animation Portfolio View 1" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
                      </div>
                      <div class="video-frame-wrapper">
                        <iframe width="100%" height="100%" src="https://www.youtube.com/embed/rwwQPtTUqD4" title="Animation Portfolio View 2" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
                      </div>
                      <div class="video-frame-wrapper">
                        <iframe width="100%" height="100%" src="https://www.youtube.com/embed/z02mF0LdvCE" title="Animation Portfolio View 3" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
                      </div>
                    </div>
                  )}
                  
                  {index === 3 && <><i>▶</i><b>YUVA</b></>}
                </div>
                <small>{placeholder}</small>
              </div>
              <div class="work-copy"><h3>{title}</h3><p>{copy}</p><span>View Portfolio (Coming soon)<b>↗</b></span></div>
            </article>
          ))}
        </div>
      </section>

      <!-- Section 04: People (Restored back to original layout & background theme with consistent heading typography) -->
      <section id="people" class="section people-section">
        <div class="container people-layout">
          <div class="people-copy">
            <p class="eyebrow">04 — People</p>
            <h2>Technology scales products.<br /><em>People scale organisations.</em></h2>
            <p>I care deeply about building environments where people are trusted, challenged, recognised, and able to grow.</p>
            <a class="text-link" href="#contact">Start a conversation <span>↗</span></a>
          </div>
          <div class="stats-list">
            <ul class="unwrapped-bullets">
              <li>
                <strong>100<span>+</span></strong>
                <p>Candidate interviews conducted to build high-performing, cross-functional teams.</p>
              </li>
              <li>
                <strong>9.5<span>+</span></strong>
                <p>Client satisfaction rating consistently maintained across major delivery pipelines.</p>
              </li>
              <li>
                <strong>19<span>+</span></strong>
                <p>Years of professional evolution bridging creative design, product leadership, and AI workflows.</p>
              </li>
            </ul>
          </div>
        </div>
      </section>

      <!-- Section 05: Insights -->
      <section id="insights" class="section container insights-section">
        <div class="section-heading split-heading">
          <div>
            <p class="eyebrow">05 — Insights</p>
            <h2>Thoughts<br /><em>in progress.</em></h2>
          </div>
          <p>Reflections on AI, design, product thinking, continuous learning, and building better ways of working.</p>
        </div>
        <div class="insights-empty">
          <div class="spark" aria-hidden="true">✦</div>
          <h3>Professional Highlights.</h3>
          <p>Explore my articles, AI transformation insights, digital strategy, UX and project management experience on LinkedIn.</p>
          <br />
          <a class="button button-outline" href="https://www.linkedin.com/in/kumarshubhek" target="_blank" rel="noreferrer">Visit LinkedIn <span>↗</span></a>
        </div>
      </section>

      <!-- Section 06: Contact -->
      <section id="contact" class="contact-section">
        <div class="container contact-inner">
          <p class="eyebrow">06 — Contact</p>
          <h2>Let’s build<br /><em>something meaningful.</em></h2>
          <p>Whether you’re exploring AI, shaping a product, improving an experience, or simply exchanging ideas, I’d be glad to connect.</p>
          <a class="button button-light" href="mailto:kumarshubhek@gmail.com">Start a conversation <span>↗</span></a>
        </div>
      </section>
    </main>

    <footer class="footer container">
      <a class="brand" href="#top">KUMAR SHUBHEK<span>.</span></a>
      <p>Still learning. Still building. Still curious.</p>
      <p>© {new Date().getFullYear()} Kumar Shubhek</p>
    </footer>
  </body>
</html>

<style>
  :global(*) { box-sizing: border-box; }
  :global(html) { scroll-behavior: smooth; background: #0b0b0d; }
  :global(body) { margin: 0; color: #f6f4ee; background: #0b0b0d; font-family: 'DM Sans', Arial, sans-serif; overflow-x: hidden; }
  :global(a) { color: inherit; }
  .container { width: min(1160px, calc(100% - 48px)); margin: 0 auto; }
  .nav-wrap { position: absolute; z-index: 5; width: 100%; top: 0; }
  .nav { display: flex; align-items: center; justify-content: space-between; height: 84px; border-bottom: 1px solid rgba(246,244,238,.12); }
  .brand { color: #f6f4ee; font-size: 1.15rem; font-weight: 700; letter-spacing: -.08em; text-decoration: none; }
  .brand span { color: #d8b45a; }
  .nav-links { display: flex; gap: 1.4rem; }
  .nav-links a, .nav-contact { color: #b6b4b0; font-size: .77rem; font-weight: 600; text-decoration: none; transition: color .2s ease; }
  .nav-links a:hover, .nav-contact:hover { color: #f6f4ee; }
  .nav-contact { color: #f6f4ee; }
  .nav-contact span { color: #d8b45a; }
  
  .hero { 
    display: grid; 
    padding: 160px 0 80px; 
    grid-template-columns: 1.1fr .9fr; 
    align-items: center; 
    gap: 4rem; 
  }
  .hero-copy { padding-right: 20px; }
  .eyebrow { display: flex; align-items: center; gap: .55rem; margin: 0 0 1.3rem; color: #d8b45a; font-family: 'DM Mono', monospace; font-size: .64rem; letter-spacing: .08em; text-transform: uppercase; }
  .eyebrow span { display: block; width: 20px; height: 1px; background: currentColor; }
  h1, h2, h3, p { margin-top: 0; }
  
  /* Unified Harmonized Heading Typography Styles */
  h2 { 
    font-weight: 500; 
    letter-spacing: -0.045em; 
    font-size: clamp(2.4rem, 4.4vw, 4.2rem);
    line-height: 1.02;
    margin-bottom: 0;
  }
  h2 em { 
    color: #d8b45a; 
    font-family: 'Playfair Display', Georgia, serif; 
    font-weight: 500; 
    font-style: italic;
    display: inline-block;
    margin-top: 0.15rem;
    letter-spacing: -0.015em;
  }

  h1 {
    max-width: 810px;
    margin-bottom: 2rem;
    font-size: clamp(3rem, 5.2vw, 5rem);
    line-height: 1.15;
    letter-spacing: -0.03em;
    font-weight: 500;
  }

  1 em {
    color: #d8b45a;
    font-family: 'Playfair Display', Georgia, serif;
    font-style: italic;
    font-weight: 500;
    letter-spacing: -0.01em;
    display: inline-block;
    margin-top: 0.2rem;
  }
  .hero-intro { max-width: 440px; color: #a5a3a0; font-size: 1.02rem; line-height: 1.65; }
  
  .hero-actions { display: flex; flex-direction: row; flex-wrap: nowrap; align-items: center; gap: 1rem; margin-top: 2rem; width: max-content; }
  .button { display: inline-flex; align-items: center; gap: .9rem; padding: .92rem 1.15rem; border-radius: 999px; font-size: .78rem; font-weight: 700; text-decoration: none; white-space: nowrap; transition: transform .2s ease, background .2s ease; }
  .button:hover { transform: translateY(-3px); }
  .button-primary { color: #0b0b0d; background: #f6f4ee; }
  .button-primary span, .button-light span { color: #967520; font-size: 1rem; }
  .text-link { color: #e5e2dc; font-size: .8rem; font-weight: 600; text-decoration: none; }
  .text-link span { margin-left: .4rem; color: #d8b45a; }
  
  .pencil-art { 
    position: relative; 
    height: 580px; 
    width: 100%; 
    border: 1px solid rgba(246,244,238,.13); 
    border-radius: 30px; 
    background: #0b0b0d; 
    overflow: hidden; 
  }

  .profile-photo { 
    width: 100%; 
    height: 100%; 
    object-fit: cover; 
    object-position: center top; 
    display: block;
    border-radius: 16px; 
  }
  .pencil-art p { position: absolute; bottom: 20px; left: 20px; margin: 0; color: #96938c; font-family: 'DM Mono', monospace; font-size: .52rem; letter-spacing: .1em; z-index: 3; }
  .overlay { position: absolute; inset: 0; background: linear-gradient(180deg, transparent 40%, rgba(11,11,13,0.85) 95%); z-index: 2; }
  .orbit { position: absolute; border: 1px solid rgba(216,180,90,.2); border-radius: 50%; z-index: 2; }
  .orbit-one { width: 330px; height: 330px; top: 46px; left: 50%; transform: translateX(-50%) rotate(-22deg); }
  .orbit-two { width: 230px; height: 230px; top: 95px; left: 50%; transform: translateX(-50%) rotate(57deg); border-color: rgba(246,244,238,.08); }
  .line { position: absolute; width: 1px; height: 150%; left: 50%; top: -25%; background: linear-gradient(transparent, rgba(216,180,90,.4), transparent); z-index: 2; }
  .line-one { transform: rotate(45deg); } .line-two { transform: rotate(-45deg); opacity: .4; }
  
  .statement-band { padding: 6.8rem 0; background: #efece5; color: #121214; }
  .statement-grid { display: grid; grid-template-columns: 1fr 2fr; gap: 3rem; }
  .statement-grid .eyebrow { color: #98761f; }
  .statement { max-width: 780px; margin: 0; font-size: clamp(2rem,4vw,4rem); font-weight: 500; letter-spacing: -.065em; line-height: 1.02; }
  .statement em { color: #98761f; font-family: 'Playfair Display', Georgia, serif; }
  
  .section { 
    padding: 9rem 0; 
    border-bottom: 1px solid rgba(246, 244, 238, 0.12);
    overflow: hidden;
  }
  .section-dark { background: #131316; }
  .section-heading { margin-bottom: 4rem; }
  .split-heading { display: grid; grid-template-columns: 1.2fr .8fr; gap: 4rem; align-items: end; }
  .split-heading > p { max-width: 380px; margin: 0 0 .25rem; color: #a5a3a0; font-size: 1rem; line-height: 1.75; }

  /* Capabilities Grid */
  .capabilities-grid { 
    display: grid; 
    grid-template-columns: repeat(3, 1fr); 
    gap: 20px; 
  }
  .capability-card { 
    background: #141414; 
    border: 1px solid #262626; 
    border-radius: 12px; 
    padding: 36px 32px; 
    transition: all 0.3s ease; 
  }
  .capability-card:hover { 
    border-color: #d8b45a; 
    transform: translateY(-4px); 
  }
  .capability-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 32px;
  }
  .cap-num { 
    font-size: 13px; 
    color: #d8b45a; 
    font-family: 'DM Mono', monospace; 
  }
  .card-icon {
    color: #d8b45a;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .capability-card h3 { 
    font-size: 22px; 
    font-weight: 500; 
    margin-bottom: 12px; 
    color: #ffffff; 
    letter-spacing: -0.02em;
    margin-top: 0;
  }
  .capability-card p { 
    font-family: 'DM Sans', sans-serif; 
    font-size: 14.5px; 
    color: #a0a0a0; 
    line-height: 1.6; 
    margin: 0; 
