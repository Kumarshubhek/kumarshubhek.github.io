    ]
  },
  {
    yearText: "2016",
    period: "AUG 2016 - Feb 2021",
    role: "Project Manager",
    company: "GENPACT (on third party payroll) | Gurgaon, India",
    stats: [
      { value: "Security", label: "Campaign Focus" },
      { value: "Gamification WBTs", label: "Global reach" }
    ],
    highlights: [
