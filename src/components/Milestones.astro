    period: "DEC 2010 - FEB 2014",
    role: "UX Designer",
    company: "Magic Software Pvt Ltd | Noida, India",
    stats: [
      { value: "eLearning", label: "Global Partner" },
      { value: "Telestration", label: "International" }
    ],
    highlights: [
      "Designed immersive UX/UI solutions, touch-enabled prototypes, and iPad applications.",
      "Crafted intuitive cross-platform interactive interfaces for global publishing partners."
    ]
  },
  {
    yearText: "2010",
    period: "SEP 2010 - DEC 2010",
    role: "Team Lead",
    company: "Espire infolabs | Delhi, India",
    stats: [
      { value: "eLearning", label: "Production Line" },
      { value: "Cross-Media", label: "Team Pipeline" }
    ],
    highlights: [
      "Led end-to-end eLearning development and multimedia production pipelines.",
      "Coordinated cross-media team deliverables for large-scale enterprise communication requirements."
    ]
  },
  {
    yearText: "2010",
    period: "MAY 2010 - SEP 2010",
    role: "Team Lead",
    company: "Sterco Digitex Pvt Limited | Delhi, India",
    stats: [
      { value: "Animation", label: "Studio Domain" },
